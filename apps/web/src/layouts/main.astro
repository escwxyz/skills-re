---
import "@/styles/global.css"
import Header from "@/components/header.astro"
import { ClientRouter } from "astro:transitions"
import type { Thing, WithContext } from "schema-dts"
import MetaSeo from "@/components/meta-seo.astro"
import { getLocale, setLocale } from "@/paraglide/runtime"

interface Props {
  title?: string
  description?: string
  image?: string
  canonicalPath?: string
  noIndex?: boolean
  structuredData?: (WithContext<Thing> | Thing)[]
  showFooter?: boolean
  showStatusBar?: boolean
  enableViewTransitions?: boolean
}

const {
  title,
  description,
  image,
  canonicalPath,
  noIndex,
  structuredData,
  showFooter = true,
  showStatusBar = true,
  enableViewTransitions = false,
} = Astro.props

const locale = getLocale()
setLocale(locale, { reload: false })
---

<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} — skills.re` : "skills.re"}</title>

    <MetaSeo
      title={title}
      description={description}
      image={image}
      canonicalPath={canonicalPath}
      noIndex={noIndex}
      structuredData={structuredData}
      locale={locale}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500;700&family=Inter+Tight:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const themeStorageKey = "theme"
      const root = document.documentElement
      let theme = "light"

      try {
        const storedTheme = window.localStorage.getItem(themeStorageKey)
        theme =
          // oxlint-disable-next-line no-nested-ternary
          storedTheme === "dark" || storedTheme === "light"
            ? storedTheme
            : // oxlint-disable-next-line unicorn/no-nested-ternary
              window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
      } catch {
        theme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light"
      }

      root.classList.toggle("dark", theme === "dark")
      root.style.colorScheme = theme
    </script>
    {enableViewTransitions && <ClientRouter />}
  </head>
  <body>
    <Header />
    <slot />
    <!-- {showFooter ? <Footer /> : null} -->
    <!-- {showStatusBar ? <StatusBar /> : null} -->
  </body>
</html>
