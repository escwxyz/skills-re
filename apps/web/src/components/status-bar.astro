---
import { CookieConsent } from "@/components/cookie-consent"

interface Props {
  statusText?: string
  skillCount?: string
}

const { statusText = "all agents aligned", skillCount = "14,208" } = Astro.props

const year = new Date().getFullYear()
---

<div
  class="text-muted-foreground bg-background/80 fixed bottom-0 left-0 z-50 flex w-full items-center justify-between border-t px-4 py-2 font-mono text-xs tracking-widest uppercase backdrop-blur-sm sm:hidden md:flex"
>
  <span>System status: {statusText} — [{skillCount} skills indexed]</span>
  <div class="flex items-center gap-2">
    <CookieConsent client:only="react" />
    <span>© {year} skills.re</span>
  </div>
</div>
