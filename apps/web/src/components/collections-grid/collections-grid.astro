---
interface CollectionGridItem {
  description: string
  skillCount: number
  slug: string
  title: string
}

interface Props {
  collections: CollectionGridItem[]
}

const { collections } = Astro.props
---

<!--
  Layout: 1 col mobile → [2fr 1fr 1fr] desktop
  Featured card (first) spans 2 rows on sm+ and gets the ink/paper treatment.
  border-l + border-t on container, border-r + border-b on each cell.
-->
<div
  class="grid grid-cols-1 border-t border-l border-(--rule) sm:grid-cols-[2fr_1fr_1fr]"
>
  {
    collections.map((col, i) => {
      const num = String(i + 1).padStart(2, "0")
      const featured = i === 0
      return (
        <a
          href={`/collections/${col.slug}`}
          class:list={[
            "flex flex-col justify-between border-r border-b border-(--rule) p-[26px_22px] no-underline transition-colors",
            featured
              ? "min-h-110 bg-(--ink) text-(--paper) hover:opacity-95 sm:row-span-2 sm:border-b-0"
              : "min-h-55 hover:bg-(--paper-2)",
            (i === 2 || i === 4) && "sm:border-r-0",
          ]}
        >
          <div>
            <div
              class:list={[
                "mb-2 flex justify-between font-mono text-[10.5px] tracking-[.14em] uppercase",
                featured ? "text-muted-text-2" : "text-(--muted-text)",
              ]}
            >
              <span>
                COLLECTION {num}
                {featured ? " — FEATURED" : ""}
              </span>
              <span>{col.skillCount} skills</span>
            </div>
            <h3
              class:list={[
                "font-display m-0 my-2 leading-none font-normal",
                featured
                  ? "text-[clamp(2rem,4vw,3.5rem)] italic"
                  : "text-[clamp(1.4rem,2.5vw,2.1rem)]",
              ]}
            >
              {col.title}
            </h3>
          </div>
          <p
            class:list={[
              "m-0 font-serif leading-[1.45]",
              featured
                ? "text-[15px] text-[#bbb3a2]"
                : "text-ink-2 text-[13px]",
            ]}
          >
            {col.description}
          </p>
        </a>
      )
    })
  }
</div>
