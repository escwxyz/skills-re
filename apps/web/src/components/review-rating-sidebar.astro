---
import { WriteReviewCta } from "@/components/write-review-cta"

interface RatingCount {
  stars: number
  count: number
}

interface Props {
  ratingAvg: number
  totalReviews: number
  recommendPct: number
  ratingCounts: RatingCount[]
  mentionedTags?: string[]
  skillId: string
}

const { ratingAvg, totalReviews, recommendPct, ratingCounts, mentionedTags, skillId } =
  Astro.props
---

<aside class="border-b md:border-b-0 md:border-r border-rule px-5 py-6 md:px-7 md:py-8">
  <!-- Mobile: score + meta + CTA in a single row -->
  <!-- Desktop: stacked column -->
  <div class="flex items-end justify-between gap-4 md:block">
    <div>
      <div class="font-display text-[72px] md:text-[96px] leading-[.85] tracking-[-0.03em]">
        {ratingAvg}<span class="text-[22px] md:text-[32px] text-muted-text">/5</span>
      </div>
      <div class="eyebrow mt-1.5 md:mt-2.5">
        {totalReviews} Reviews · {recommendPct}% Recommend
      </div>
    </div>

    <!-- CTA: inline on mobile, full-width block on desktop -->
    <div class="shrink-0 md:hidden">
      <WriteReviewCta skillId={skillId} client:load />
    </div>
  </div>

  <!-- Rating bars: hidden on mobile to save space -->
  <div class="hidden md:flex mt-6 flex-col gap-1.5">
      {
        ratingCounts.map(({ stars, count }) => {
          const pct = totalReviews > 0 ? Math.round((count / totalReviews) * 100) : 0
          return (
            <div class="grid grid-cols-[12px_1fr_32px] items-center gap-2 font-mono text-[11px]">
            <span class="text-muted-text">{stars}</span>
            <div class="h-1 bg-rule">
              <div class="h-full bg-ink" style={`width: ${pct}%`} />
            </div>
            <span class="text-muted-text text-right">{count}</span>
          </div>
        )
      })
    }
  </div>

  <!-- Mentioned tags: hidden on mobile -->
  {
    mentionedTags && mentionedTags.length > 0 && (
      <div class="hidden md:block border-t border-rule mt-7 pt-6">
        <div class="eyebrow text-editorial-red mb-3">§ Mentioned Tags</div>
        <div class="flex flex-wrap gap-1.5">
          {
            mentionedTags.map((tag) => (
              <span class="font-mono text-[10px] tracking-[.12em] uppercase px-2.5 py-1 border border-rule text-ink-2">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    )
  }

  <!-- CTA: full-width block on desktop only -->
  <div class="hidden md:block mt-8">
    <WriteReviewCta skillId={skillId} client:load />
  </div>
</aside>
