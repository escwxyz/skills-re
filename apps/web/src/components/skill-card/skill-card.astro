---
interface LegacySkillCard {
  description: string
  id: string
  installs: string
  latency: string
  passRate: string
  size: string
  slug: string
  title: string
  variant?: "default" | "accent" | "accent-2" | "accent-3" | "italic"
  version: string
}

interface Props {
  skill: LegacySkillCard
  noBorderRight?: boolean
}

const { skill, noBorderRight } = Astro.props

const titleColorClass = {
  default: "",
  accent: "text-editorial-red",
  "accent-2": "text-editorial-blue italic",
  "accent-3": "text-editorial-green",
  italic: "italic",
}[skill.variant ?? "default"]
---

<a
  class:list={[
    "border-rule hover:bg-paper-2 flex min-h-90 flex-col border-b px-4.5 pt-4.5 pb-5 no-underline transition-colors hover:no-underline",
    noBorderRight ? "border-r-0" : "border-rule border-r",
  ]}
  href={`/skills/${skill.slug}`}
>
  <div class="ph -mx-4.5 -mt-4.5 mb-3.5 aspect-4/3">
    <span class="ph-label">{skill.title}</span>
  </div>
  <div
    class="text-muted-text mb-1 flex justify-between font-mono text-[10px] tracking-[.14em] uppercase"
  >
    <span>SKILL_ID: {skill.id}</span>
    <b class="text-ink font-medium"
      >{skill.version === "BETA" ? "BETA" : `v.${skill.version}`}</b
    >
  </div>
  <h4
    class:list={[
      "font-display my-2.5 text-[24px] leading-[1.05] font-normal",
      titleColorClass,
    ]}
    set:html={skill.title.replace("-", "-<br/>")}
  />
  <p class="text-ink-2 mb-auto pb-3.5 font-serif text-[13px] leading-normal">
    {skill.description}
  </p>
  <div
    class="border-rule text-muted-text grid grid-cols-2 gap-3.5 border-t pt-3 font-mono text-[10px] tracking-[.14em] uppercase"
  >
    <div>
      PASS RATE<b class="text-ink block text-[12px] font-medium"
        >{skill.passRate}</b
      >
    </div>
    <div>
      LATENCY<b class="text-ink block text-[12px] font-medium"
        >{skill.latency}</b
      >
    </div>
    <div>
      INSTALLS<b class="text-ink block text-[12px] font-medium"
        >{skill.installs}</b
      >
    </div>
    <div>
      SIZE<b class="text-ink block text-[12px] font-medium">{skill.size}</b>
    </div>
  </div>
</a>
