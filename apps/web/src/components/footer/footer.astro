---
import { defaultLocale, getIntlayer, getLocaleFromPath } from "intlayer"
import type { LocalesValues } from "intlayer"

interface Props {
  className?: string
}

const { className = "" } = Astro.props

const locale = (getLocaleFromPath(Astro.url.pathname) ??
  defaultLocale) as LocalesValues

const {
  description,
  legalCookies,
  legalImprint,
  legalPrivacy,
  legalTerms,
  legalTitle,
  platformAuthors,
  platformCollections,
  platformIndex,
  platformSearch,
  platformTitle,
  publishChangelog,
  publishDocs,
  publishSigning,
  publishSubmit,
  publishTitle,
} = getIntlayer("footer", locale)
---

<footer
  class:list={[
    "border-border mx-auto mt-7.5 mb-1.5 grid w-full grid-cols-1 gap-8 border-t-[3px] px-2.5 py-10 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr]",
    className,
  ]}
>
  <div>
    <div class="font-display mb-4 text-[40px] leading-none italic">
      skills.<em>re</em>
    </div>
    <p class="text-ink-2 font-serif text-[13px]">
      {description}
    </p>
  </div>
    <div>
      <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {platformTitle}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/registry">{platformIndex}</a></li>
      <li><a href="/collections">{platformCollections}</a></li>
      <li><a href="/authors">{platformAuthors}</a></li>
      <li><a href="/search">{platformSearch}</a></li>
    </ul>
  </div>
  <div>
    <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {publishTitle}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/submit">{publishSubmit}</a></li>
      <li><a href="/changelog">{publishChangelog}</a></li>
      <li><a href="#">{publishDocs}</a></li>
      <li><a href="#">{publishSigning}</a></li>
    </ul>
  </div>
  <div>
    <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {legalTitle}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/imprint">{legalImprint}</a></li>
      <li><a href="/terms">{legalTerms}</a></li>
      <li><a href="/privacy">{legalPrivacy}</a></li>
      <li><a href="/cookies">{legalCookies}</a></li>
    </ul>
  </div>
</footer>
