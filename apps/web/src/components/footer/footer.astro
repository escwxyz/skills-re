---
import { defaultLocale, getIntlayer, getLocaleFromPath } from "intlayer"
import type { LocalesValues } from "intlayer"

interface Props {
  className?: string
}

const { className = "" } = Astro.props

const locale = (getLocaleFromPath(Astro.url.pathname) ??
  defaultLocale) as LocalesValues

const { description, menus } = getIntlayer("footer", locale)
---

<footer
  class:list={[
    "border-border mx-auto mt-7.5 mb-1.5 grid w-full grid-cols-1 gap-8 border-t-[3px] px-2.5 py-10 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr]",
    className,
  ]}
>
  <div>
    <div class="font-display mb-4 text-[40px] leading-none italic">
      skills.<em>re</em>
    </div>
    <p class="text-ink-2 font-serif text-[13px]">
      {description}
    </p>
  </div>
  <div>
    <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {menus.platform.title}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/registry">{menus.platform.index}</a></li>
      <li><a href="/collections">{menus.platform.collections}</a></li>
      <li><a href="/authors">{menus.platform.authors}</a></li>
      <li><a href="/search">{menus.platform.search}</a></li>
    </ul>
  </div>
  <div>
    <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {menus.publish.title}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/submit">{menus.publish.submit}</a></li>
      <li><a href="/changelog">{menus.publish.changelog}</a></li>
      <li><a href="#">{menus.publish.docs}</a></li>
      <li><a href="#">{menus.publish.signing}</a></li>
    </ul>
  </div>
  <div>
    <h6 class="mb-3 font-mono text-[10.5px] tracking-[.16em] uppercase">
      {menus.legal.title}
    </h6>
    <ul
      class="text-ink-2 m-0 list-none p-0 font-mono text-[11px] leading-loose"
    >
      <li><a href="/imprint">{menus.legal.imprint}</a></li>
      <li><a href="/terms">{menus.legal.terms}</a></li>
      <li><a href="/privacy">{menus.legal.privacy}</a></li>
      <li><a href="/cookies">{menus.legal.cookies}</a></li>
    </ul>
  </div>
</footer>
