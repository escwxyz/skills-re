---
import type { SkillFrontmatterData } from "@/lib/skill-detail-data"

type Props = SkillFrontmatterData

const { name, description, license, compatibility, metadata, allowedTools } =
  Astro.props

const fields: { lbl: string; val: string }[] = [
  { lbl: "name", val: name },
  { lbl: "description", val: description },
  ...(license ? [{ lbl: "license", val: license }] : []),
  ...(compatibility ? [{ lbl: "compatibility", val: compatibility }] : []),
  ...(allowedTools ? [{ lbl: "allowed-tools", val: allowedTools }] : []),
]
---

<aside
  class="text-muted-text hidden self-start font-mono text-[11px] leading-[1.7] lg:sticky lg:top-[70px] lg:block"
>
  <h6
    class="text-muted-text mb-2 font-mono text-[10.5px] tracking-[0.18em] uppercase"
  >
    Frontmatter
  </h6>
  {
    fields.map((item) => (
      <div class="border-rule text-ink-2 border-t py-2">
        <b class="text-ink block font-medium">{item.lbl}</b>
        {item.val}
      </div>
    ))
  }
  {
    metadata && Object.keys(metadata).length > 0 && (
      <div class="border-rule text-ink-2 border-t py-2">
        <b class="text-ink block font-medium">metadata</b>
        {Object.entries(metadata).map(([k, v]) => (
          <div>
            <span class="text-muted-text">{k}:</span> {v}
          </div>
        ))}
      </div>
    )
  }
</aside>
