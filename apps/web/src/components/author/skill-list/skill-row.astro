---
import type { AuthorSkillRowData } from "@/lib/author-data"

interface Props {
  skill: AuthorSkillRowData
}

const { skill } = Astro.props

const metrics = [
  { label: "AUDIT", val: skill.auditScoreLabel },
  { label: "INST", val: skill.downloadsLabel },
  { label: "STARS", val: skill.starsLabel },
]
---

<a
  href={`/skills/${skill.slug}`}
  class="border-border grid grid-cols-[32px_1fr] items-baseline gap-4 border-b border-dashed py-4.5 no-underline sm:grid-cols-[50px_1fr] md:grid-cols-[50px_1fr_80px_80px_80px] md:gap-5"
>
  <div class="text-muted-foreground font-mono text-[11px] tracking-[.14em]">
    {String(skill.index + 1).padStart(2, "0")}.
  </div>
  <div>
    <h4 class="font-display m-0 mb-1 text-[clamp(20px,3vw,28px)] font-normal">
      {skill.title}
    </h4>
    <div class="text-ink-2 max-w-130 font-serif text-sm leading-normal">
      {skill.description}
    </div>
    <div
      class="text-muted-foreground mt-1.5 font-mono text-[10px] tracking-[.14em] uppercase"
    >
      {skill.id} · {skill.latestVersionLabel} · {skill.licenseLabel}
    </div>
    <div class="mt-3 flex gap-5 md:hidden">
      {
        metrics.map((m) => (
          <div class="text-muted-foreground font-mono text-[10.5px] tracking-[.08em] uppercase">
            {m.label}
            <b class="font-display text-foreground block text-sm font-medium tracking-normal normal-case">
              {m.val}
            </b>
          </div>
        ))
      }
    </div>
  </div>
  {
    metrics.map((m) => (
      <div class="text-muted-foreground hidden font-mono text-[10.5px] tracking-[.08em] uppercase md:block">
        {m.label}
        <b class="font-display text-foreground block text-sm font-medium tracking-normal normal-case">
          {m.val}
        </b>
      </div>
    ))
  }
</a>
