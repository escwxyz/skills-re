---
import type { AuthorSkillRowData } from "@/lib/author-data"

interface Props {
  skill: AuthorSkillRowData
}

const { skill } = Astro.props

const metrics = [
  { label: "AUDIT", val: skill.auditScoreLabel },
  { label: "INST", val: skill.downloadsLabel },
  { label: "STARS", val: skill.starsLabel },
]
---

<a
  href={`/skills/${skill.slug}`}
  class="grid grid-cols-[32px_1fr] gap-4 border-b border-dashed border-border py-[18px] items-baseline no-underline sm:grid-cols-[50px_1fr] md:grid-cols-[50px_1fr_80px_80px_80px] md:gap-5"
>
  <div class="font-mono text-[11px] tracking-[.14em] text-muted-foreground">
    {String(skill.index + 1).padStart(2, "0")}.
  </div>
  <div>
    <h4 class="m-0 mb-1 font-display text-[clamp(20px,3vw,28px)] font-normal">
      {skill.title}
    </h4>
    <div class="max-w-[520px] font-serif text-sm leading-[1.5] text-ink-2">
      {skill.description}
    </div>
    <div
      class="mt-1.5 font-mono text-[10px] tracking-[.14em] uppercase text-muted-foreground"
    >
      {skill.id} · {skill.latestVersionLabel} · {skill.licenseLabel}
    </div>
    <div class="mt-3 flex gap-5 md:hidden">
      {
        metrics.map((m) => (
          <div class="font-mono text-[10.5px] tracking-[.08em] uppercase text-muted-foreground">
            {m.label}
            <b class="block font-display text-sm font-medium normal-case tracking-normal text-foreground">
              {m.val}
            </b>
          </div>
        ))
      }
    </div>
  </div>
  {
    metrics.map((m) => (
      <div class="hidden font-mono text-[10.5px] tracking-[.08em] uppercase text-muted-foreground md:block">
        {m.label}
        <b class="block font-display text-sm font-medium normal-case tracking-normal text-foreground">
          {m.val}
        </b>
      </div>
    ))
  }
</a>
