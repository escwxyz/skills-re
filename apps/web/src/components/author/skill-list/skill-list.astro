---
import AuthorSkillRow from "./skill-row.astro"
import type { AuthorSkillRowData } from "@/lib/author-data"

interface Props {
  skills: AuthorSkillRowData[]
  skillCount: number
}

const { skills, skillCount } = Astro.props
---

<div class="py-9 pr-6 pl-4 md:pr-8 md:pl-6">
  <div
    class="mb-[22px] flex items-baseline justify-between border-b border-border pb-3"
  >
    <h3 class="m-0 font-display text-[32px] font-normal">Published Skills</h3>
    <div
      class="font-mono text-[10.5px] tracking-[.14em] uppercase text-muted-foreground"
    >
      § {skillCount} total · sorted by installs
    </div>
  </div>

  {skills.map((skill) => <AuthorSkillRow skill={skill} />)}

  {
    skills.length === 0 && (
      <p class="font-serif italic text-muted-foreground">
        No skills published yet.
      </p>
    )
  }
</div>
