---
import type { AuthorActivityItem } from "@/lib/author-data"

interface Props {
  items: AuthorActivityItem[]
}

const { items } = Astro.props
---

<aside class="px-6 py-9 md:pl-8">
  <div
    class="border-border mb-5.5 flex items-baseline justify-between border-b pb-3"
  >
    <h3 class="font-display m-0 text-2xl font-normal">Activity</h3>
    <div
      class="text-muted-foreground font-mono text-[10.5px] tracking-[.14em] uppercase"
    >
      § latest skill updates
    </div>
  </div>

  {items.length > 0 ? (
    items.map((act) => (
      <div class="border-border grid grid-cols-[90px_1fr] gap-3 border-b border-dashed py-2.5 font-mono text-[11.5px]">
        <span class="text-muted-foreground tracking-[.08em]">{act.dateLabel}</span>
        <span>
          {act.text} <b class="text-destructive font-medium">{act.itemLabel}</b>
        </span>
      </div>
    ))
  ) : (
    <p class="font-serif italic text-muted-foreground">
      No public skill activity available yet.
    </p>
  )}
</aside>
