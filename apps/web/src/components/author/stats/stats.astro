---
import type { AuthorStatsData } from "@/lib/author-data"

interface Props {
  stats: AuthorStatsData
}

const { stats } = Astro.props
---

<div
  class="grid grid-cols-2 border-b-[3px] border-border sm:grid-cols-3 md:grid-cols-5"
>
  {
    stats.metrics.map((stat) => (
      <div class="border-r border-border py-[22px] px-5 last:border-r-0">
        <div class="font-display text-[46px] leading-none font-normal">
          {stat.value}
        </div>
        <div class="mt-2 font-mono text-[10px] tracking-[.14em] uppercase text-muted-foreground">
          {stat.label}
        </div>
      </div>
    ))
  }
</div>
