---
// import { getIntlayer } from "intlayer"
// import translations from "./index.i18n"

// const { title } = getIntlayer("index")

const steps = [
  {
    num: "i.",
    title: "Publish a folder.",
    body: "A skill is a directory with a skill.md, optional assets, and an evals file. Sign it, skr publish, done. No build step. No manifest gymnastics.",
    meta: "§ Author",
  },
  {
    num: "ii.",
    title: "Review in public.",
    body: "Every version is diffable against the last. Evals run on every push. Reviews are public, attributed, and can be contested in the open.",
    meta: "§ Registry",
  },
  {
    num: "iii.",
    title: "Mount & run.",
    body: "Install into any agent runtime in one line. Sandbox the skill against your own fixtures before handing it real work.",
    meta: "§ Operator",
  },
]
---

<section>
  <div class="section-title">
    <h3>How it works</h3>
    <div class="eyebrow">§ in three movements</div>
  </div>
  <div class="border-border grid grid-cols-1 border-b sm:grid-cols-3">
    {
      steps.map((step) => (
        <div class="border-border border-b px-5.5 py-7 last:border-b-0 sm:border-r sm:border-b-0 sm:last:border-r-0">
          <div class="font-display text-muted-text-2 text-[72px] leading-none italic">
            {step.num}
          </div>
          <h5 class="font-display mt-2.5 mb-2 text-[28px] leading-[1.05] font-normal">
            {step.title}
          </h5>
          <p class="text-ink-2 m-0 font-serif text-sm leading-normal">
            {step.body}
          </p>
          <div class="border-border text-muted-foreground mt-4.5 border-t pt-3.5 font-mono text-[10.5px] tracking-[.14em] uppercase">
            {step.meta}
          </div>
        </div>
      ))
    }
  </div>
</section>
