---
import { m } from "@/paraglide/messages"
import { localizeHref } from "@/paraglide/runtime"
import { NewsletterForm } from "@/components/newsletter-form"
import { AgentLogoCloud } from "@/components/agent-logo-cloud"

const req = Astro.request
const ip =
  req.headers.get("cf-connecting-ip") ??
  req.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ??
  null
const country = req.headers.get("cf-ipcountry") ?? null
const city = req.headers.get("cf-ipcity") ?? null
const ua = req.headers.get("user-agent") ?? ""
const device: "mobile" | "desktop" = /mobile/i.test(ua) ? "mobile" : "desktop"
---

<section
  class="border-border grid grid-cols-1 gap-8 border-b py-6 md:grid-cols-[3fr_2fr]"
>
  <div
    class="border-border border-b pb-8 md:border-r md:border-b-0 md:pr-8 md:pb-0"
  >
    <div class="mb-2 flex items-center gap-2.5">
      <span class="bg-destructive inline-block h-2 w-2 rounded-full"></span>
      <span
        class="text-destructive font-mono text-[10.5px] tracking-[.2em] uppercase"
      >
        {m.home_hero_leading({})}
      </span>
    </div>
    <h2
      class="font-display my-1 mb-4 text-[clamp(40px,6vw,74px)] leading-[.94] font-normal tracking-[-0.015em]"
    >
      {m.home_hero_not_a_package({})}
      <em>{m.home_hero_a_practice({})}</em><br />{m.home_hero_a_skill_is_an({})}
      <em>{m.home_hero_instruction({})}</em>{m.home_hero_not_an_install({})}
    </h2>
    <p class="text-ink-2 mb-5 max-w-155 font-serif text-[20px] leading-[1.4]">
      {m.home_hero_description({})}
    </p>
    <div class="mt-4.5 mb-2.5 flex flex-wrap gap-3">
      <a href={localizeHref("/skills")} class="btn">
        {m.home_hero_browse_index({})}
        <span>→</span>
      </a>
      <a href={localizeHref("/submit")} class="btn ghost">
        {m.home_hero_publish_skill({})}
      </a>
    </div>
    <div
      class="text-muted-foreground mt-6.5 font-mono text-[10.5px] tracking-[.14em] uppercase"
    >
      {m.home_hero_filed({})}
    </div>
  </div>

  <div class="grid content-start gap-5 pl-0 md:pl-2">
    <div>
      <span
        class="text-muted-foreground font-mono text-[10.5px] tracking-[.14em]"
        >[01]</span
      >
      <p
        class="text-muted-foreground mt-1.5 font-serif text-[13.5px] leading-normal italic"
      >
        Stay current with new skill releases, curated collections, and
        dispatches from the agent ecosystem. No noise — pure signal.
      </p>
    </div>

    <div
      class="text-muted-foreground/60 font-mono text-[10px] tracking-[.12em] uppercase"
    >
      Vol. 1 // Issue 01 &mdash; EST. 2025
    </div>

    <hr class="border-border" />

    <div>
      <div
        class="text-muted-foreground mb-3 font-mono text-[10.5px] tracking-[.2em] uppercase"
      >
        Circulation
      </div>
      <h3
        class="font-display mb-4 text-[28px] leading-[1.05] font-normal tracking-[-0.01em]"
      >
        Join the registry
      </h3>
      <NewsletterForm
        client:load
        initialIp={ip}
        initialCountry={country}
        initialCity={city}
        initialDevice={device}
      />
    </div>

    <div class="grid grid-cols-2 gap-x-4 gap-y-3 pt-1">
      <div>
        <span
          class="text-muted-foreground/70 font-mono text-[10px] tracking-[.12em]"
          >[02]</span
        >
        <p
          class="text-muted-foreground mt-1 font-serif text-[12px] leading-[1.4] italic"
        >
          Dispatched twice a month. Unsubscribe any time.
        </p>
      </div>
      <div>
        <span
          class="text-muted-foreground/70 font-mono text-[10px] tracking-[.12em]"
          >[03]</span
        >
        <p
          class="text-muted-foreground mt-1 font-serif text-[12px] leading-[1.4] italic"
        >
          By practitioners, for practitioners building with agents.
        </p>
      </div>
    </div>

    <AgentLogoCloud client:visible />
  </div>
</section>
