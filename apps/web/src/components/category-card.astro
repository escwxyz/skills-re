---
import { m } from "@/paraglide/messages"
import type { CategoryCardItem } from "@/lib/registry-data"
import { getLocale, localizeHref } from "@/paraglide/runtime"

interface Props {
  category: CategoryCardItem
  href?: string
}

const { category, href = localizeHref(`/categories/${category.id}`) } = Astro.props

const titleVariantClass = {
  default: "",
  accent: "text-destructive",
  blue: "text-editorial-blue italic",
  green: "text-editorial-green",
  italic: "italic",
}[category.variant ?? "default"]

const locale = getLocale()
---

<a
  href={href}
  class="bg-background hover:bg-secondary flex min-h-80 flex-col p-[22px_18px_20px] no-underline hover:no-underline"
>
  <div class="text-muted-foreground mb-2.5 font-mono text-[10.5px] tracking-[.14em] uppercase">
    {category.num}
  </div>
  <h4
    class:list={[
      "font-display mt-0 mb-3 text-[36px] leading-[.95] font-normal",
      titleVariantClass,
    ]}
  >
    {category.title}
  </h4>
  <p class="text-ink-2 mb-auto font-serif text-sm leading-normal">
    {category.description}
  </p>
  <div class="text-muted-foreground mt-4.5 flex gap-4.5 font-mono text-[10.5px] tracking-widest uppercase">
    <div>
      {m.category_card_skills({})}
      <b class="text-foreground block font-medium">{category.skillCount.toLocaleString(locale)}</b>
    </div>
    {
      category.passRate && (
        <div>
          {m.category_card_pass_rate({})}
          <b class="text-foreground block font-medium">{category.passRate}</b>
        </div>
      )
    }
  </div>
</a>
