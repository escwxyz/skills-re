---
interface Props {
  authorName: string
  dateLabel: string
  stars: number
  bodyHtml: string
  title?: string
  versionLabel?: string
  tags?: string[]
  isLast?: boolean
}

const { authorName, dateLabel, stars, bodyHtml, title, versionLabel, tags = [], isLast } =
  Astro.props
---

<article class:list={["px-4 py-6 md:px-7 md:py-8", !isLast && "border-b border-rule"]}>
  <!-- Meta row: stacks on mobile, single row on md+ -->
  <div class="flex flex-col gap-0.5 md:flex-row md:justify-between md:items-baseline font-mono text-[10px] md:text-[11px] tracking-widest uppercase text-muted-text mb-3">
    <div>
      <b class="text-ink font-semibold">{authorName}</b>
    </div>
    <div class="text-muted-text-2 md:text-muted-text">
      {dateLabel}
      {versionLabel ? ` · ${versionLabel}` : ""}
    </div>
  </div>

  <!-- Stars -->
  <div class="text-[16px] md:text-[18px] tracking-widest mb-2">
    {
      Array.from({ length: 5 }).map((_, i) => (
        <span class:list={[i < stars ? "text-ink" : "text-rule"]}>★</span>
      ))
    }
  </div>

  {
    title && (
      <h3 class="font-display text-[20px] md:text-[26px] font-normal italic leading-[1.15] tracking-[-0.01em] mb-3">
        "{title}"
      </h3>
    )
  }

  <!-- Body -->
  <div
    class="font-serif text-[14px] md:text-[16px] leading-[1.6] text-ink-2 mb-4 max-w-180"
    set:html={bodyHtml}
  />

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="flex gap-1.5 flex-wrap">
        {tags.map((tag) => (
          <span class="font-mono text-[10px] tracking-[.12em] uppercase px-2.5 py-1 border border-rule text-ink-2">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</article>
