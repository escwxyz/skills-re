---
import { ThemeToggle } from "@/components/theme-toggle"
import { LoginDialog } from "@/components/login-dialog"
import { MobileMenu } from "@/components/mobile-menu"
import { buttonVariants } from "@/components/ui/button"
import { CloudArrowUpIcon, MagnifyingGlassIcon } from "@phosphor-icons/react"
import { defaultLocale, getLocaleFromPath, getIntlayer } from "intlayer"
import type { LocalesValues } from "intlayer"
import { isLoginDialogOpenAtom } from "@/stores/app"
import { LanguageSwitcher } from "@/components/language-switcher"

const { user: currentUser } = Astro.locals

const isActive = (href: string) => Astro.url.pathname.includes(href)
const { pathname } = Astro.url

const locale = (getLocaleFromPath(Astro.url.pathname) ??
  defaultLocale) as LocalesValues
const { authors, categories, collections, docs, skills, submit } = getIntlayer(
  "header",
  locale
)
const mobileMenuContent = getIntlayer("mobile-menu", locale)

const MENUS = [
  { label: skills, path: "skills" },
  { label: categories, path: "categories" },
  { label: collections, path: "collections" },
  { label: authors, path: "authors" },
  { label: docs, path: "docs" },
]

const mobileContent = {
  title: mobileMenuContent.title,
  close: mobileMenuContent.close,
  description: mobileMenuContent.description,
  skills: mobileMenuContent.skills,
  collections: mobileMenuContent.collections,
  authors: mobileMenuContent.authors,
  search: mobileMenuContent.search,
}
---

<header
  class="bg-background/80 sticky top-0 z-100 grid place-items-center border-b pr-3 pl-6 font-mono text-[11px] tracking-[0.08em] uppercase backdrop-blur-sm"
  style="height: var(--header-height)"
>
  <nav class="grid w-full grid-cols-[1fr_auto_1fr] items-center">
    <div class="hidden items-center gap-4.5 md:flex">
      {
        MENUS.map((menu) => (
          <a
            href={`/${menu.path}`}
            class={
              isActive(`/${menu.path}`) ? "underline" : "text-muted-foreground"
            }
          >
            {menu.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center md:hidden">
      <MobileMenu
        client:load
        currentPathname={pathname}
        locale={locale}
        content={mobileContent}
      />
    </div>

    <a
      href="/"
      class="font-display text-foreground text-center text-[22px] tracking-normal normal-case italic"
      ><b class="font-serif not-italic">skills</b><i>.re</i></a
    >
    <div class="flex items-center justify-end gap-4.5">
      <a
        href="/search"
        class={`hidden md:inline ${isActive("/search") ? "underline" : "text-muted-foreground"}`}
        ><MagnifyingGlassIcon size={20} /></a
      >
      <ThemeToggle className="hidden md:block" client:load />
      <LanguageSwitcher
        className="hidden md:flex"
        locale={locale}
        client:load
      />
      <a
        href="/submit"
        class:list={["no-underline", buttonVariants({ variant: "secondary" })]}
      >
        <CloudArrowUpIcon />
        <span class="hidden md:inline">{submit}</span>
      </a>
      {
        currentUser ? (
          <a href="/account">{currentUser.name}</a>
        ) : (
          <LoginDialog
            onOpenChange={(open) => !open && isLoginDialogOpenAtom.set(false)}
            client:load
            locale={locale}
          />
        )
      }
    </div>
  </nav>
</header>
