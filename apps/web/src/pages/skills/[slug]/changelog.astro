---
import SkillLayout from "@/layouts/skill-detail.astro"
import { createServerClient } from "@/lib/server-orpc"
import { getSkillChangelogPageData } from "@/lib/skill-detail-data"

const { slug } = Astro.params
const client = createServerClient(Astro.request)
const pageData = slug ? await getSkillChangelogPageData(client, slug) : null

if (!pageData) {
  return Astro.redirect("/skills")
}
---

<SkillLayout
  skill={pageData.layout}
  activeTab="changelog"
  title={`Changelog · ${pageData.layout.title} — skills.re`}
>
  <div class="mx-auto max-w-4xl px-4 py-8 md:px-10 md:py-12">
    <div
      class="border-rule mb-10 flex items-start justify-between gap-6 border-b pb-8"
    >
      <div>
        <div class="eyebrow text-editorial-red mb-3">§ Snapshot History</div>
        <h2
          class="font-display text-[clamp(36px,5vw,52px)] leading-none font-normal tracking-tight"
        >
          Changelog
        </h2>
      </div>
      <!-- <a
        href={`/skills/${pageData.layout.slug}/diff#skill-tabs`}
        class="btn shrink-0 font-mono text-[10.5px] tracking-widest uppercase"
      >
        Compare Versions →
      </a> -->
    </div>

    {
      pageData.entries.length > 0 ? (
        <div>
          {pageData.entries.map((entry, index) => (
            <div
              class:list={[
                index < pageData.entries.length - 1
                  ? "border-rule border-b"
                  : "",
                "py-10 first:pt-0",
              ]}
            >
              <div class="mb-5 flex flex-wrap items-baseline justify-between gap-4">
                <div class="flex flex-wrap items-center gap-3">
                  <span
                    class={`flex items-center gap-1.5 font-mono text-sm tracking-wide ${entry.isCurrent ? "text-(--editorial-red)" : "text-(--ink)"}`}
                  >
                    {entry.isCurrent ? "▲" : "○"}
                    <b class="font-semibold">v.{entry.version}</b>
                    {entry.isCurrent && (
                      <span class="font-mono text-[9.5px] tracking-[.18em] text-(--editorial-red) uppercase">
                        Current
                      </span>
                    )}
                  </span>
                  {entry.shaLabel && (
                    <span class="text-muted-text font-mono text-[10px] tracking-[.14em] uppercase">
                      SHA {entry.shaLabel}
                    </span>
                  )}
                </div>
                <span class="text-muted-text font-mono text-[11px] tracking-[.06em] whitespace-nowrap">
                  {entry.dateLabel}
                </span>
              </div>

              <h3 class="font-display mb-3.5 text-[clamp(22px,3vw,30px)] leading-tight tracking-tight">
                {entry.title}
              </h3>

              <p class="text-muted-foreground m-0 max-w-170 font-serif text-base leading-relaxed">
                {entry.body}
              </p>
            </div>
          ))}
        </div>
      ) : (
        <div class="border-rule bg-paper-2 border px-5 py-6">
          <div class="eyebrow text-editorial-red mb-2">§ Changelog</div>
          <p class="text-ink-2 m-0 max-w-110">
            No snapshot history is available for this skill yet.
          </p>
        </div>
      )
    }
  </div>
</SkillLayout>
