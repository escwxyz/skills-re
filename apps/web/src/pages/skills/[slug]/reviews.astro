---
import SkillLayout from "@/layouts/skill-detail.astro"
import ReviewCard from "@/components/review-card.astro"
import ReviewRatingSidebar from "@/components/review-rating-sidebar.astro"
import { createServerClient } from "@/lib/server-orpc"
import { getSkillReviewsPageData } from "@/lib/skill-detail-data"

const { slug } = Astro.params
const client = createServerClient(Astro.request)
const pageData = slug ? await getSkillReviewsPageData(client, slug) : null

if (!pageData) {
  return Astro.redirect("/skills")
}
---

<SkillLayout
  skill={pageData.layout}
  activeTab="reviews"
  title={`Reviews · ${pageData.layout.title} — skills.re`}
>
  <div class="grid min-h-150 grid-cols-1 md:grid-cols-[280px_1fr]">
    <ReviewRatingSidebar
      ratingAvg={pageData.ratingAvg}
      totalReviews={pageData.totalReviews}
      recommendPct={pageData.recommendPct}
      ratingCounts={pageData.ratingCounts}
      skillId={pageData.layout.id}
    />

    <div>
      {
        pageData.reviews.length > 0 ? (
          pageData.reviews.map((review) => (
            <ReviewCard
              authorName={review.authorName}
              bodyHtml={review.bodyHtml}
              dateLabel={review.dateLabel}
              isLast={review.isLast}
              stars={review.stars}
              title={review.title}
              versionLabel={review.versionLabel}
            />
          ))
        ) : (
          <div class="px-4 py-8 md:px-7 md:py-10">
            <div class="border-rule bg-paper-2 border px-5 py-6">
              <div class="eyebrow text-editorial-red mb-2">§ Reviews</div>
              <p class="text-ink-2 m-0 max-w-110">
                No public reviews are available for this skill yet.
              </p>
            </div>
          </div>
        )
      }

      <!-- Load more -->
      <div
        class="border-rule eyebrow text-muted-text flex items-center justify-between border-t px-4 py-5 md:px-7 md:py-6"
      >
        <span>Showing {pageData.totalReviews} public reviews</span>
        <span>Latest public feedback</span>
      </div>
    </div>
  </div>
</SkillLayout>
