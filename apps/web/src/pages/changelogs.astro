---
import Layout from "@/layouts/main.astro";
import { render } from "astro:content";
import { getChangelogs } from "@/lib/content";
import { getLocaleForUrl } from "@/paraglide/runtime";

const locale = Astro.currentLocale ?? getLocaleForUrl(Astro.url.pathname);
const changelogs = await getChangelogs(locale);
const rendered = await Promise.all(
  changelogs.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const typeLabel: Record<string, string> = {
  major: "Major",
  feature: "Feature",
  patch: "Patch",
};
---

<Layout
  title="Changelog"
  description="New features, improvements, and fixes to the skills.re registry."
  canonicalPath="/changelogs"
>
  <div class="mx-auto max-w-3xl px-6 py-16">

    <!-- Header -->
    <div class="border-rule mb-12 border-b pb-8">
      <p class="eyebrow text-editorial-red mb-2">§ Platform</p>
      <h1 class="font-display text-5xl font-normal">Changelog</h1>
      <p class="text-ink-2 font-serif mt-4 text-lg leading-relaxed">
        New features, improvements, and fixes — in order of release.
      </p>
    </div>

    <!-- Entries -->
    <div>
      {
        rendered.map(({ entry, Content }, i) => {
          const { title, description, type, versionMajor, versionMinor, versionPatch, isStable, date, changes } = entry.data;
          const version = `${versionMajor}.${versionMinor}.${versionPatch}`;
          const formattedDate = date.toLocaleDateString(locale, { dateStyle: "long" });
          const isLast = i === rendered.length - 1;

          return (
            <article class:list={["py-10", !isLast && "border-rule border-b"]}>
              <!-- Version + meta row -->
              <div class="mb-5 flex flex-wrap items-center gap-x-4 gap-y-1.5">
                <span class="font-mono text-2xl font-medium tabular-nums">
                  v{version}
                </span>
                <span
                  class:list={[
                    "font-mono text-[10px] tracking-[.14em] uppercase px-1.5 py-0.5 border",
                    type === "major" && "border-editorial-red text-editorial-red",
                    type === "feature" && "border-editorial-blue text-editorial-blue",
                    type === "patch" && "border-rule text-muted-foreground",
                  ]}
                >
                  {typeLabel[type]}
                </span>
                {!isStable && (
                  <span class="font-mono text-[10px] tracking-[.14em] uppercase px-1.5 py-0.5 border border-rule text-muted-foreground">
                    Pre-release
                  </span>
                )}
                <time
                  datetime={date.toISOString()}
                  class="text-muted-foreground font-mono text-[10.5px] tracking-[.08em] uppercase ml-auto"
                >
                  {formattedDate}
                </time>
              </div>

              <!-- Title + description -->
              <h2 class="font-display text-2xl font-normal">{title}</h2>
              <p class="text-ink-2 font-serif mt-1.5 text-base leading-relaxed">
                {description}
              </p>

              <!-- Change list -->
              <ul class="mt-5 space-y-1.5">
                {changes.map((change) => (
                  <li class="flex items-start gap-2.5 font-mono text-[12px] leading-relaxed">
                    <span class="text-muted-foreground mt-px shrink-0">—</span>
                    <span>{change}</span>
                  </li>
                ))}
              </ul>

              <!-- Long-form body (optional) -->
              {
                /* render Content only when it has actual nodes beyond the frontmatter */
              }
              <div class="prose prose-neutral dark:prose-invert mt-6 font-serif text-sm empty:hidden">
                <Content />
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Footer CTA -->
    <div class="border-rule mt-4 border-t pt-8">
      <p class="eyebrow text-muted-foreground mb-4">Stay up to date</p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/changelogs/feed.xml"
          class="border-rule hover:bg-paper-2 border px-4 py-2 font-mono text-xs tracking-[.06em] transition-colors"
        >
          RSS feed →
        </a>
        <a
          href="https://github.com/skills-re/registry"
          class="border-rule hover:bg-paper-2 border px-4 py-2 font-mono text-xs tracking-[.06em] transition-colors"
        >
          GitHub →
        </a>
      </div>
    </div>
  </div>
</Layout>
