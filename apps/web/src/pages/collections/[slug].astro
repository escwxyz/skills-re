---
import Layout from "@/layouts/main.astro"
import { CollectionItem } from "@/components/collection-item"
import {
  formatCollectionLicenseMix,
  formatCollectionPassRate,
  formatCollectionSkillPassRate,
  formatCollectionTotalDownloads,
  formatCollectionTotalFileSize,
} from "@/lib/collection-data"
import { createServerClient } from "@/lib/server-orpc"
import { formatCompactNumber } from "@/lib/registry-data"

const { slug } = Astro.params
const client = createServerClient(Astro.request)
const collection = slug
  ? await client.collections.getBySlug({ slug }).catch(() => null)
  : null

if (!collection) {
  return Astro.redirect("/collections")
}

const skills = collection.skills.map((s) => ({
  description: s.description,
  id: s.id,
  installs:
    typeof s.downloadsAllTime === "number"
      ? formatCompactNumber(s.downloadsAllTime)
      : "—",
  passRate: formatCollectionSkillPassRate(s),
  publisherName: s.author?.name ?? s.authorHandle ?? "—",
  tags: s.tags ?? [],
  slug: s.slug,
  title: s.title,
  version: s.latestVersion ?? "—",
}))

const passingSkills = formatCollectionPassRate(collection.skills)
const totalDownloads = formatCollectionTotalDownloads(collection.skills)
const totalFileSize = formatCollectionTotalFileSize(collection.skills)
const licenseMix = formatCollectionLicenseMix(collection.skills)

const metaItems = [
  { lbl: "Skills", val: String(collection.skills.length) },
  { lbl: "Total Downloads", val: totalDownloads },
  { lbl: "License Mix", val: licenseMix },
  { lbl: "Total File Size", val: totalFileSize },
  { lbl: "Passing", val: passingSkills, accent: true },
]
---

<Layout title={`${collection.title} — skills.re`}>
  <!-- HERO: full-width, no image -->
  <section class="border-b border-(--rule) px-5 py-10 md:px-10 md:py-16">
    <div
      class="mb-4 font-mono text-[10.5px] tracking-[.2em] text-(--editorial-red) uppercase"
    >
      ● Collection · {collection.slug}
    </div>
    <h1
      class="font-display m-0 mb-5 text-[clamp(2.8rem,8vw,7rem)] leading-[.88] font-normal tracking-tight"
    >
      {collection.title}
    </h1>
    <p
      class="text-ink-2 m-0 max-w-3xl font-serif text-[clamp(1rem,2vw,1.4rem)] leading-relaxed"
    >
      {collection.description}
    </p>
  </section>

  <!-- META BAR: 2 cols mobile → 5 cols desktop -->
  <div
    class="grid grid-cols-2 border-b-[3px] border-(--rule) font-mono text-[10.5px] tracking-widest uppercase sm:grid-cols-3 md:grid-cols-5"
  >
    {
      metaItems.map((m, i) => (
        <div
          class={`border-r border-(--rule) px-4 py-3.5 text-(--muted-text) last:border-r-0 ${
            i === 1 ? "border-(--rule) sm:border-r-0 md:border-r" : ""
          }`}
        >
          {m.lbl}
          <b
            class={`font-display mt-1 block text-base font-medium ${m.accent ? "text-editorial-green" : "text-(--ink)"}`}
          >
            {m.val}
          </b>
        </div>
      ))
    }
  </div>

  <!-- EDITORIAL INTRO: stacked mobile → 3 cols desktop -->
  <section
    class="grid grid-cols-1 gap-0 border-b border-(--rule) md:grid-cols-[1fr_2fr] lg:grid-cols-3"
  >
    <aside
      class="border-b border-(--rule) px-5 py-8 font-mono text-[11px] leading-relaxed text-(--muted-text) md:border-r md:border-b-0 md:px-7"
    >
      <b
        class="mb-1.5 block font-medium tracking-widest text-(--ink) uppercase"
      >
        § Editor's note
      </b>
      This is a <em>working</em> collection — updated as our stack changes. If a skill
      falls out of rotation, it falls out of the list. No grandfathering.
      <br /><br />
      <b
        class="mb-1.5 block font-medium tracking-widest text-(--ink) uppercase"
      >
        § Mount all
      </b>
      <span class="tracking-wider break-all text-(--ink)"
        >skr install @skills.re/{collection.slug}</span
      >
    </aside>

    <div
      class="border-b border-(--rule) px-5 py-8 text-[17px] leading-[1.6] font-(--font-serif) md:px-8 lg:border-r lg:border-b-0"
    >
      <p class="dropcap m-0 mb-4">
        The first hour of a sprint is not for coding. It is for <em>triage</em>:
        sifting through the weekend's pull requests, the overnight on-call
        alerts, and the half-finished thought a colleague left in Slack at
        eleven on Friday. What follows is the set of skills that makes that hour
        tolerable.
      </p>
      <p class="m-0 mb-4">
        Each skill has earned its spot by surviving contact with a real queue
        and a reviewer who does not tolerate nits. They are ordered not by
        popularity, but by the order in which I reach for them.
      </p>
      <p class="m-0">
        The collection is free to install in full, or cherry-picked. I've noted,
        for each one, the <em>specific</em> problem it solves.
      </p>
    </div>

    <aside
      class="hidden px-5 py-8 font-mono text-[11px] leading-relaxed text-(--muted-text) md:px-7 lg:block"
    >
      <b
        class="mb-1.5 block font-medium tracking-widest text-(--ink) uppercase"
      >
        § In this collection
      </b>
      <div class="mt-2 leading-loose">
        {
          skills.map((s, i) => (
            <div class="truncate">
              {String(i + 1).padStart(2, "0")} · {s.title}
            </div>
          ))
        }
      </div>
    </aside>
  </section>

  <!-- COLLECTION SKILL ITEMS -->
  {skills.map((skill, i) => <CollectionItem skill={skill} index={i} />)}

  <!-- TAIL -->
  <div class="border-b border-(--rule) px-5 py-12 text-center">
    <div
      class="font-mono text-[11px] tracking-[.16em] text-(--muted-text) uppercase"
    >
      End of Collection
    </div>
    <div class="font-display my-2 text-[32px] italic">— skills.re</div>
    <div
      class="font-mono text-[11px] tracking-[.16em] text-(--muted-text) uppercase"
    >
      Thanks for reading.
    </div>
    <div class="mt-6 flex justify-center">
      <a href="/collections" class="btn ghost">← All Collections</a>
    </div>
  </div>
</Layout>
