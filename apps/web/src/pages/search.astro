---
import Layout from "@/layouts/main.astro"
import PageHero from "@/components/page-hero.astro"
import { SkillList } from "@/components/skill-list"
import { SearchRateLimitPrompt } from "@/components/search-rate-limit-prompt"
import { createServerClient } from "@/lib/server-orpc"
import { getSearchPageData } from "@/lib/search-data"

const client = createServerClient(Astro.request)
const pageData = await getSearchPageData(client, Astro.url.searchParams)
---

<Layout
  title={pageData.query
    ? `"${pageData.query}" — Search — skills.re`
    : "Search — skills.re"}
>
  <PageHero
    eyebrow={pageData.mode === "search"
      ? "§ Search · Semantic AI"
      : "§ Search · Skill Registry"}
    description={pageData.note}
    descriptionItalic
    stats={[
      { label: "Mode", value: "Semantic AI", accent: "blue" },
      ...(pageData.mode === "search"
        ? [{ label: "Results", value: pageData.resultLabel }]
        : []),
    ]}
  >
    {
      pageData.mode === "search" ? (
        <>
          Results for{" "}
          <em class="text-editorial-red">"{pageData.titleLabel}"</em>
        </>
      ) : (
        <>
          Search the <em class="text-editorial-blue">registry.</em>
        </>
      )
    }
  </PageHero>

  <section class="border-rule border-b">
    <form
      method="GET"
      action="/search"
      class="grid grid-cols-1 md:grid-cols-[1fr_auto]"
    >
      <div class="flex items-center">
        <span class="text-editorial-red px-6 font-mono text-[18px]">›</span>
        <input
          type="search"
          name="q"
          value={pageData.query}
          placeholder="describe what you're looking for…"
          class="font-display border-0 px-0 py-5 text-[28px] tracking-[-0.01em] focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="border-rule bg-ink text-paper border-t px-6 py-5 font-mono text-[11px] tracking-[.14em] uppercase md:border-t-0 md:border-l"
      >
        Search →
      </button>
    </form>
  </section>

  {
    pageData.mode === "search" && (
      <section class="border-rule bg-paper-2 text-muted-text border-b px-6 py-3 font-mono text-[10px] tracking-[.14em] uppercase">
        <span>{pageData.resultLabel}</span>
      </section>
    )
  }

  <section>
    {
      pageData.mode === "rate_limited" ? (
        <SearchRateLimitPrompt client:load />
      ) : pageData.items.length > 0 ? (
        <SkillList skills={pageData.items} />
      ) : pageData.mode === "search" ? (
        <div class="px-6 py-12">
          <div class="border-rule bg-paper-2 max-w-120 border px-5 py-6">
            <div class="eyebrow text-editorial-red mb-2">§ Search</div>
            <p class="text-ink-2 m-0">
              No skills matched your semantic search. Try rephrasing your query.
            </p>
          </div>
        </div>
      ) : (
        <div class="px-6 py-12">
          <div class="border-rule bg-paper-2 max-w-120 border px-5 py-6">
            <div class="eyebrow text-editorial-blue mb-2">§ Semantic AI</div>
            <p class="text-ink-2 m-0">
              Describe what you're looking for and the AI will find the most
              relevant skills from the registry.
            </p>
          </div>
        </div>
      )
    }
  </section>
</Layout>
