---
import Layout from "@/layouts/main.astro"
import { PageHero } from "@/components/page-hero"
import { SkillList } from "@/components/skill-list"
import { createServerClient } from "@/lib/server-orpc"
import { getSearchPageData } from "@/lib/search-data"

const client = createServerClient(Astro.request)
const pageData = await getSearchPageData(client, Astro.url.searchParams)
---

<Layout
  title={pageData.query ? `"${pageData.query}" — Search — skills.re` : "Search — skills.re"}
>
  <PageHero
    eyebrow={pageData.mode === "search" ? "§ Search · Public Skill Index" : "§ Search · Popular Skills"}
    description={pageData.note}
    descriptionItalic
    stats={[
      { label: "Scope", value: "Skills only", accent: "red" },
      { label: "Results", value: pageData.resultLabel },
    ]}
  >
    {pageData.mode === "search" ? (
      <>
        Results for <em class="text-editorial-red">"{pageData.titleLabel}"</em>
      </>
    ) : (
      <>
        Search the <em class="text-editorial-blue">registry.</em>
      </>
    )}
  </PageHero>

  <section class="border-b border-rule">
    <form method="GET" action="/search" class="grid grid-cols-1 md:grid-cols-[1fr_auto]">
      <div class="flex items-center">
        <span class="px-6 font-mono text-[18px] text-editorial-red">›</span>
        <input
          type="search"
          name="q"
          value={pageData.query}
          placeholder="search skills by title or description…"
          class="border-0 px-0 py-5 font-display text-[28px] tracking-[-0.01em] focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="border-t border-rule bg-ink px-6 py-5 font-mono text-[11px] tracking-[.14em] uppercase text-paper md:border-t-0 md:border-l"
      >
        Search →
      </button>
    </form>
  </section>

  <section class="border-b border-rule bg-paper-2 px-6 py-3 font-mono text-[10px] tracking-[.14em] uppercase text-muted-text">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <span>{pageData.resultLabel}</span>
      <span>Authors and collections will appear once the unified search contract exists.</span>
    </div>
  </section>

  <section>
    {pageData.items.length > 0 ? (
      <SkillList skills={pageData.items} />
    ) : (
      <div class="px-6 py-12">
        <div class="max-w-120 border border-rule bg-paper-2 px-5 py-6">
          <div class="eyebrow text-editorial-red mb-2">§ Search</div>
          <p class="m-0 text-ink-2">
            No public skill matches were found for this query.
          </p>
        </div>
      </div>
    )}
  </section>
</Layout>
