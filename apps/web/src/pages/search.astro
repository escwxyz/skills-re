---
import Layout from "@/layouts/main.astro"
import PageHero from "@/components/page-hero.astro"
import { SemanticSearchPanel } from "@/components/semantic-search-panel"
import { getSearchPageData } from "@/lib/search-data"
import { createServerClient } from "@/lib/server-orpc"

const client = createServerClient(Astro.request)
const pageData = await getSearchPageData(client, Astro.url.searchParams)
---

<Layout
  title={pageData.query
    ? `"${pageData.query}" - Search - skills.re`
    : "Search - skills.re"}
>
  <PageHero
    eyebrow="§ Search · Semantic AI"
    description="Ask the registry in natural language. Cloudflare RAG resolves the best matches, and the page shows loading skeletons while results are still in flight."
    descriptionItalic
    stats={[{ label: "Mode", value: "Cloudflare RAG", accent: "blue" }]}
  >
    Search the <em class="text-editorial-blue">registry.</em>
  </PageHero>

  <SemanticSearchPanel client:load initialData={pageData} />
</Layout>
