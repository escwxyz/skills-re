---
import Layout from "@/layouts/main.astro"
import { PageHero } from "@/components/page-hero"
import { createServerClient } from "@/lib/server-orpc"
import { getAuthorsIndexData } from "@/lib/author-data"

const client = createServerClient(Astro.request)
const pageData = await getAuthorsIndexData(client)
---

<Layout title="Authors — skills.re">
  <PageHero
    eyebrow="§ The Register · Authors & Houses"
    description="The people and teams who write, maintain, and sign skills on the registry. This directory is currently backed by the public author contract and the live skill index."
    descriptionItalic
    stats={pageData.stats}
  >
    A roster of <em>hands</em><br />and <em class="text-editorial-blue"
      >houses.</em
    >
  </PageHero>

  <!-- TOP AUTHORS -->
  <section style="border-bottom: 3px solid var(--rule);">
    <div
      style="display: flex; justify-content: space-between; align-items: baseline; padding: 28px 24px 14px;"
    >
      <h2
        style="font-family: var(--font-display); font-size: 44px; margin: 0; font-weight: 400;"
      >
        The top of the <em style="color: var(--editorial-red);">roster.</em>
      </h2>
      <div
        style="font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted-text);"
      >
        By reputation · Updated hourly
      </div>
    </div>

    <div
      style="display: grid; grid-template-columns: 1.4fr 1fr 1fr; border-top: 1px solid var(--rule);"
    >
      {
        pageData.topAuthors.map((author, i) => (
          <a
            href={`/authors/${author.handle}`}
            style={`padding: 28px 24px; border-right: 1px solid var(--rule); position: relative; color: inherit; display: block; text-decoration: none;${i === 2 ? " border-right: 0;" : ""}`}
          >
            <div
              style={`position: absolute; top: 18px; right: 20px; font-family: var(--font-display); font-style: italic; font-size: 72px; line-height: 1; color: var(--muted-text-2);`}
            >
              № {String(i + 1).padStart(2, "0")}
            </div>

            {i === 0 && (
              <div style="width: 120px; height: 120px; border-radius: 50%; background: var(--ink); color: var(--paper); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-style: italic; font-size: 64px; border: 4px double var(--paper); outline: 1px solid var(--ink); margin-bottom: 22px;">
                {author.avatarLabel}
              </div>
            )}

            <div style="font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted-text); margin-bottom: 12px;">
              Public author
              {author.isVerified ? " · Verified ▣" : ""}
            </div>
            <h3
              style={`font-family: var(--font-display); font-size: ${i === 0 ? "76px" : "44px"}; line-height: 1; font-weight: 400; margin: 6px 0 12px; letter-spacing: -.02em; color: ${i === 1 ? "var(--editorial-red)" : i === 2 ? "var(--editorial-blue)" : "var(--ink)"};`}
            >
              {author.name}
            </h3>
            <p
              style={`font-family: var(--font-serif); font-size: ${i === 0 ? "18px" : "15.5px"}; color: var(--ink-2); line-height: 1.55; max-width: ${i === 0 ? "520px" : "400px"}; margin: 0 0 16px;`}
            >
              Signed skills published by @{author.handle}. Public profile fields
              are limited to the current author contract.
            </p>
            <div style="font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted-text); display: flex; gap: 20px;">
              <span>
                Skills{" "}
                <b style="color: var(--ink); font-weight: 500;">
                  {author.skillCountLabel}
                </b>
              </span>
              <span>
                Repos{" "}
                <b style="color: var(--ink); font-weight: 500;">
                  {author.repoCountLabel}
                </b>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- AUTHORS GRID -->
  <div style="padding: 36px 24px 10px;">
    <h2
      style="font-family: var(--font-display); font-size: 44px; margin: 0; font-weight: 400;"
    >
      The register, in <em
        style="font-style: italic; color: var(--editorial-blue);"
        >alphabetical</em
      >
      order.
    </h2>
  </div>

  <div style="padding: 0 24px 60px;">
    <div
      style="display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--rule);"
    >
      {
        pageData.alphabeticalAuthors.map((author, i) => (
          <a
            href={`/authors/${author.handle}`}
            style={`display: grid; grid-template-columns: 56px 1fr; gap: 14px; padding: 20px 24px; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); color: inherit; align-items: start; text-decoration: none;${(i + 1) % 3 === 0 ? " border-right: 0;" : ""}`}
          >
            <div
              style={`width: 48px; height: 48px; border-radius: 50%; background: ${author.isVerified ? "var(--ink)" : "var(--paper)"}; color: ${author.isVerified ? "var(--paper)" : "var(--ink)"}; border: 1px solid var(--rule); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-style: italic; font-size: 24px;`}
            >
              {author.avatarLabel}
            </div>
            <div>
              <h4 style="font-family: var(--font-display); font-size: 22px; font-weight: 400; line-height: 1.1; margin: 0 0 2px;">
                @{author.handle}
              </h4>
              <div style="font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .08em; color: var(--muted-text); margin-bottom: 8px;">
                public author
                {author.isVerified && (
                  <span style="color: var(--editorial-green);">
                    {" "}
                    · verified ▣
                  </span>
                )}
              </div>
              <p style="font-family: var(--font-serif); font-size: 13.5px; color: var(--ink-2); line-height: 1.5; margin: 0 0 10px;">
                {author.name}
              </p>
              <div style="font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted-text); display: flex; gap: 14px;">
                <span>
                  Skills{" "}
                  <b style="color: var(--ink); font-weight: 500;">
                    {author.skillCountLabel}
                  </b>
                </span>
                <span>
                  Repos{" "}
                  <b style="color: var(--ink); font-weight: 500;">
                    {author.repoCountLabel}
                  </b>
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
