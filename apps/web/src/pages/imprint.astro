---
import Layout from "@/layouts/main.astro"
import { render } from "astro:content"
import { getPage } from "@/lib/content"
import { getLocaleForUrl } from "@/paraglide/runtime"

const locale = Astro.currentLocale ?? getLocaleForUrl(Astro.url.pathname)
const entry = await getPage("imprint", locale)
if (!entry) {
  return Astro.redirect("/404")
}

const { Content } = await render(entry)
const { title, description, updatedAt } = entry.data
---

<Layout title={title} description={description} canonicalPath="/imprint">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <div class="border-rule mb-10 border-b pb-8">
      <p
        class="text-muted-foreground mb-2 font-mono text-[10.5px] tracking-[.14em] uppercase"
      >
        Legal
      </p>
      <h1 class="font-display text-5xl font-normal">{title}</h1>
      {
        description && (
          <p class="text-ink-2 mt-4 font-serif text-lg leading-relaxed">
            {description}
          </p>
        )
      }
      <p
        class="text-muted-foreground mt-6 font-mono text-[10.5px] tracking-[.12em] uppercase"
      >
        Last updated {updatedAt.toLocaleDateString(locale, { dateStyle: "long" })}
      </p>
    </div>
    <article
      class="prose prose-neutral dark:prose-invert max-w-none font-serif"
    >
      <Content />
    </article>
  </div>
</Layout>
