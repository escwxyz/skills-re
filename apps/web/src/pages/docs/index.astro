---
import Layout from "@/layouts/main.astro"
import { getDocs } from "@/lib/content"
import { getLocale, localizeHref } from "@/paraglide/runtime"

const locale = getLocale()
const docs = await getDocs(locale)
// const firstSlug = docs[0]?.id.split("/")[1]

const localizedDocsHref = localizeHref("/docs", { locale })
const localizedDocHref = (slug: string) =>
  localizeHref(`/docs/${slug}`, { locale })
---

<Layout title="Documentation" canonicalPath={localizedDocsHref}>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="border-rule mb-10 border-b pb-8">
      <p
        class="text-muted-foreground mb-2 font-mono text-[10.5px] tracking-[.14em] uppercase"
      >
        Registry
      </p>
      <h1 class="font-display text-5xl font-normal">Documentation</h1>
      <p class="text-ink-2 mt-4 font-serif text-lg leading-relaxed">
        Everything you need to install, use, and publish skills for AI agents.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        docs.map((doc) => {
          const slug = doc.id.split("/")[1]
          return (
            <a
              href={localizedDocHref(slug)}
              class="border-rule hover:bg-paper-2 block rounded-none border p-6 transition-colors"
            >
              {doc.data.category && (
                <p class="text-muted-foreground mb-2 font-mono text-[10px] tracking-[.14em] uppercase">
                  {doc.data.category}
                </p>
              )}
              <h2 class="font-display text-xl font-normal">{doc.data.title}</h2>
              {doc.data.description && (
                <p class="text-muted-foreground mt-2 font-serif text-sm leading-relaxed">
                  {doc.data.description}
                </p>
              )}
            </a>
          )
        })
      }
    </div>
  </div>
</Layout>
