---
import Layout from "@/layouts/main.astro"
import { PageHero } from "@/components/page-hero"
import { SkillCard } from "@/components/skill-card"
import { getLocale } from "@/paraglide/runtime"
import {
  getCategoryPresentation,
  toCategoryCardItem,
  toSkillCardItem,
} from "@/lib/registry-data"
import { createServerClient } from "@/lib/server-orpc"

const { slug } = Astro.params
const client = createServerClient(Astro.request)

if (!slug) {
  // oxlint-disable-next-line unicorn/prefer-module
  return Astro.redirect("/categories")
}

const categoryDetail = await client.categories.getBySlug({ slug })
if (!categoryDetail) {
  // oxlint-disable-next-line unicorn/prefer-module
  return Astro.redirect("/categories")
}

const categories = await client.categories.list({ all: true, limit: 100 })
const categoryCards = categories.map((category, index) =>
  toCategoryCardItem(category, index)
)
const categoryPresentation = getCategoryPresentation(
  categoryDetail.slug,
  categoryCards.length
)
const currentCategory =
  categoryCards.find((category) => category.id === categoryDetail.slug) ??
  ({
    description: categoryDetail.description,
    id: categoryDetail.slug,
    num: categoryPresentation.num,
    skillCount: categoryDetail.count,
    title: categoryDetail.name,
    variant: categoryPresentation.variant,
  } as const)

const categoryPage = {
  category: {
    ...currentCategory,
    description: categoryDetail.description,
    skillCount: categoryDetail.count,
    title: categoryDetail.name,
  },
  otherCategories: categoryCards.filter(
    (category) => category.id !== categoryDetail.slug
  ),
  relatedTags: categoryDetail.relatedTags,
  topSkills: categoryDetail.topSkills.map(toSkillCardItem),
}

const locale = getLocale()

const titleVariantClass = {
  default: "",
  accent: "text-destructive",
  blue: "text-editorial-blue italic",
  green: "text-editorial-green",
  italic: "italic",
}[categoryPage.category.variant ?? "default"]
---

<Layout
  title={`${categoryPage.category.title} — Classifications`}
  description={categoryPage.category.description}
  canonicalPath={`/categories/${categoryPage.category.id}`}
>
  <!-- BREADCRUMB -->
  <div
    class="border-border text-muted-foreground flex items-center gap-1.5 border-b px-6 py-2.5 font-mono text-[10.5px] tracking-[.14em] uppercase"
  >
    <a href="/categories" class="hover:text-foreground transition-colors"
      >Categories</a
    >
    <span>/</span>
    <span class="text-foreground font-medium"
      >{categoryPage.category.title}</span
    >
  </div>

  <!-- HERO -->
  <PageHero
    eyebrow={`Classification ${categoryPage.category.num}`}
    description={categoryPage.category.description}
    borderThick
  >
    <span class:list={[titleVariantClass]}>{categoryPage.category.title}</span>
    <div
      slot="aside"
      class="text-muted-foreground space-y-1 font-mono text-[11px] tracking-widest uppercase"
    >
      <div>
        Skills Indexed{" "}
        <b class="text-foreground font-medium"
          >{categoryPage.category.skillCount.toLocaleString(locale)}</b
        >
      </div>
      <div>
        Related Tags{" "}
        <b class="text-editorial-green font-medium">
          {categoryPage.relatedTags.length.toLocaleString(locale)}
        </b>
      </div>
    </div>
  </PageHero>

  <!-- RELATED TAGS -->
  {
    categoryPage.relatedTags.length > 0 && (
      <section class="border-border border-b px-6 py-6">
        <div class="text-muted-foreground mb-3 font-mono text-[10px] tracking-[.16em] uppercase">
          Related Tags
        </div>
        <div class="flex flex-wrap gap-2">
          {categoryPage.relatedTags.map(({ slug: tag, count }) => (
            <a
              href={`/skills?tag=${tag}`}
              class="border-border text-muted-foreground hover:border-foreground hover:text-foreground rounded-none border px-3 py-1.5 font-mono text-[10.5px] tracking-widest uppercase transition-colors"
            >
              #{tag} · {count}
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- TOP SKILLS -->
  <section class="border-border border-b px-6 py-10">
    <div class="mb-6 flex items-center justify-between gap-4">
      <div>
        <div
          class="text-muted-foreground font-mono text-[11px] tracking-[.16em] uppercase"
        >
          Top Skills
        </div>
        <div
          class="text-muted-foreground mt-1 font-mono text-[10.5px] tracking-[.12em] uppercase"
        >
          {categoryPage.category.skillCount.toLocaleString(locale)} skills in this
          classification
        </div>
      </div>
      <a
        href={`/skills?category=${categoryPage.category.id}`}
        class="border-border text-muted-foreground hover:text-foreground rounded-none border px-4 py-2 font-mono text-[10px] tracking-[.14em] uppercase transition-colors"
      >
        See All Skills →
      </a>
    </div>

    {
      categoryPage.topSkills.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3">
          {categoryPage.topSkills.map((skill) => (
            <SkillCard skill={skill} />
          ))}
        </div>
      ) : (
        <div class="border-border text-muted-foreground border px-6 py-10 font-mono text-sm">
          No skills published in this classification yet.
        </div>
      )
    }
  </section>

  <!-- RELATED CLASSIFICATIONS -->
  <section class="border-border border-b px-6 py-8">
    <div
      class="text-muted-foreground mb-4 font-mono text-[10px] tracking-[.16em] uppercase"
    >
      Other Classifications
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-2">
      {
        categoryPage.otherCategories.map((category) => (
          <a
            href={`/categories/${category.id}`}
            class="text-muted-foreground hover:text-foreground font-mono text-[10.5px] tracking-widest uppercase transition-colors"
          >
            {category.num} {category.title}
          </a>
        ))
      }
    </div>
  </section>
</Layout>
