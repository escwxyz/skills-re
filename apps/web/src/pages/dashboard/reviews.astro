---
import Layout from "@/layouts/main.astro"
import { DashboardReviewsPage } from "@/components/dashboard/reviews-page"
import { m } from "@/paraglide/messages"

const currentUser = Astro.locals.user as {
  email?: string | null
  github?: string | null
  id?: string
  image?: string | null
  name?: string | null
} | null
---

<Layout
  title={`${m.dashboard_reviews_title()} — skills.re`}
  showFooter={false}
  showStatusBar={false}
>
  <DashboardReviewsPage client:only="react" currentUser={currentUser} />
</Layout>
