---
import Layout from "@/layouts/main.astro"
import { DashboardShell } from "@/layouts/dashboard-shell"
import { DashboardSettings } from "@/components/dashboard/settings"
import { m } from "@/paraglide/messages"

const currentUser = Astro.locals.user as {
  email?: string | null
  github?: string | null
  id?: string
  image?: string | null
  name?: string | null
} | null
---

<Layout
  title={`${m.dashboard_settings_page_title()} — skills.re`}
  showFooter={false}
  showStatusBar={false}
  enableViewTransitions
>
  <DashboardShell client:load activeRoute="settings" currentUser={currentUser}>
    <DashboardSettings currentUser={currentUser} />
  </DashboardShell>
</Layout>
