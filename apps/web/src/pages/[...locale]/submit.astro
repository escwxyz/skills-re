---
import Layout from "@/layouts/main.astro"
import { SubmitHero } from "@/components/submit-hero"
import { SubmitSkillTabs } from "@/components/submit-skill-tabs"
import { defaultLocale, getLocaleFromPath } from "intlayer"
import type { LocalesValues } from "intlayer"

const locale = (getLocaleFromPath(Astro.url.pathname) ??
  defaultLocale) as LocalesValues
---

<Layout title="Submit a Skill — skills.re">
  <SubmitHero />
  <SubmitSkillTabs locale={locale} client:only="react" />
</Layout>
